{
  "manifest_version": 3,
  "name": "AI Page Summarizer",
  "version": "1.0.0",
  "description": "Summarize any webpage using AI.",

  "permissions": [
  "activeTab",
  "scripting",
  "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Summarizer"
  },

  "background": {
    "service_worker": "background.js"
  }
}